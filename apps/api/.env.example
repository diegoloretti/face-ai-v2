# Copiar para .env.local e preencher. NUNCA commitar .env.local.
PORT=8080
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
# Gerar via: pnpm --filter @face-ai/api exec node scripts/generate-jwt-keys.mjs
# Formato base64 (sem aspas, sem \n - o app decodifica automaticamente):
JWT_PRIVATE_KEY_PEM=BASE64_DA_CHAVE_PRIVADA
JWT_PUBLIC_KEY_PEM=BASE64_DA_CHAVE_PUBLICA
ALLOWED_ORIGIN=http://localhost:5173
