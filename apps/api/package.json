{
  "name": "@face-ai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/copy-models.mjs && node --env-file-if-exists=.env.local --watch --import tsx src/server.ts",
    "build": "node scripts/copy-models.mjs && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "node scripts/copy-models.mjs && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings=0",
    "prepare:models": "node scripts/copy-models.mjs"
  },
  "dependencies": {
    "@face-ai/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@hono/zod-validator": "^0.4.0",
    "@supabase/supabase-js": "^2.46.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vladmandic/human": "^3.3.6",
    "hono": "^4.11.4",
    "jose": "^5.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
